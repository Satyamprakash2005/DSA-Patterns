https://leetcode.com/problems/longest-substring-without-repeating-characters/description/

class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int n=s.size();
        int l=0,r=0,len=0;
        while(r<n){
            r++;
            for(int i=l;i<r;i++){
                if(s[r]==s[i]){
                    l=i+1;
                }else{
                    len=max(len,r-l);
                }
            }
        }
        return len;
    }
};