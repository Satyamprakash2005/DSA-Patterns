class Solution {
  public:
    // Function to find the length of a loop in the linked list.
    int countNodesinLoop(Node *head) {
        // Code here
        if (head == NULL || head->next == NULL) {
            return 0; // No cycle possible
        }
        Node* slow=head;
        Node* fast=head;
        int ans=1;
        while(fast!=NULL && fast->next!=NULL)
        {
            slow=slow->next;
            fast=fast->next->next;
            if(slow==fast){
                slow=slow->next;
                while(slow!=fast){
                ans++;
                slow=slow->next;
                }
                return ans;
            }
        }
        return 0;
    }
};