/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    vector<string> binaryTreePaths(TreeNode* root) {
        vector<string>ans;
        string str="";
        generatePath(root,str,ans);
        return ans;
    }
    void generatePath(TreeNode* root,string str,vector<string>&ans){
        if(root==NULL)return;
        if(root->left==NULL && root->right==NULL){
            str+=to_string(root->val);
            ans.push_back(str);
            return;
        }
        str+=to_string(root->val);
        str+="->";
        generatePath(root->left,str,ans);
        generatePath(root->right,str,ans);
    }
};